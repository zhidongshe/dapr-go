.page-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.product-card {
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.product-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.product-name {
  font-size: 32rpx;
  font-weight: 600;
}

.buy-button {
  margin: 0;
  min-width: 200rpx;
}

.state-card {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  align-items: center;
}

.state-title {
  font-size: 32rpx;
  font-weight: 600;
}

.retry-button {
  width: 240rpx;
}
