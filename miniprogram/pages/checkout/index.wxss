.address-card,
.product-card,
.summary-card,
.submit-bar,
.state-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.section-title,
.state-title,
.address-receiver {
  font-size: 32rpx;
  font-weight: 600;
}

.address-content,
.address-empty {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.address-placeholder,
.address-text {
  color: #4b5563;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.row:first-of-type {
  margin-top: 24rpx;
}

.label {
  color: #6b7280;
}

.total-row {
  padding-top: 16rpx;
  border-top: 1rpx solid #e5e7eb;
}

.submit-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.submit-button,
.action-button {
  margin: 0;
  min-width: 220rpx;
}
